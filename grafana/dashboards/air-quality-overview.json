{
  "title": "Lakehouse Pulse - Air Quality & Pipeline",
  "uid": "lakehouse-pulse-airq",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Air Quality Today (PM2.5 / PM10 / CO)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "lakehouse_pulse_air_quality_pm25_avg",
          "legendFormat": "PM2.5 avg"
        },
        {
          "refId": "B",
          "expr": "lakehouse_pulse_air_quality_pm10_avg",
          "legendFormat": "PM10 avg"
        },
        {
          "refId": "C",
          "expr": "lakehouse_pulse_air_quality_co_avg",
          "legendFormat": "CO avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Seconds Since Last Successful Ingestion",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - lakehouse_pulse_ingestion_last_success_timestamp_seconds",
          "legendFormat": "seconds"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1800
              },
              {
                "color": "red",
                "value": 5400
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Ingestion RED (Rate / Errors)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(lakehouse_pulse_ingestion_runs_total[30m])",
          "legendFormat": "run rate"
        },
        {
          "refId": "B",
          "expr": "rate(lakehouse_pulse_ingestion_run_errors_total[30m])",
          "legendFormat": "run error rate"
        },
        {
          "refId": "C",
          "expr": "rate(lakehouse_pulse_ingestion_publish_errors_total[30m])",
          "legendFormat": "publish error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}
